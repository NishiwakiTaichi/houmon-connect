<%= form_with(model: [ :admin, user ]) do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <p class="fw-bold mb-1">入力内容を確認してください</p>
      <ul class="mb-0">
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :name, class: "form-label fw-bold small" %>
      <%= f.text_field :name, class: "form-control", placeholder: "例: 山田 太郎" %>
    </div>
    <div class="col-md-6">
      <%= f.label :kana, class: "form-label fw-bold small" %>
      <%= f.text_field :kana, class: "form-control", placeholder: "例: やまだ たろう" %>
      <div class="form-text">検索で使うため、ふりがな(ひらがな)を入力してください。</div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :email, class: "form-label fw-bold small" %>
    <%= f.email_field :email, class: "form-control", placeholder: "例: yamada@example.com" %>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :job, class: "form-label fw-bold small" %>
      <%= f.select :job, User.jobs.keys.map { |k| [ t("enums.user.job.#{k}"), k ] }, {}, { class: "form-select" } %>
    </div>
    <div class="col-md-6">
      <%= f.label :role, class: "form-label fw-bold small" %>
      <%= f.select :role, User.roles.keys.map { |k| [ t("enums.user.role.#{k}"), k ] }, {}, { class: "form-select" } %>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-md-6">
      <%= f.label :password, class: "form-label fw-bold small" %>
      <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
      <% if user.persisted? %>
        <div class="form-text">変更しない場合は空のままにしてください。</div>
      <% end %>
    </div>
    <div class="col-md-6">
      <%= f.label :password_confirmation, class: "form-label fw-bold small" %>
      <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>
  </div>

  <div class="form-check mb-4">
    <%= f.check_box :active, class: "form-check-input" %>
    <%= f.label :active, "在籍中", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-teal" %>
    <%= link_to "キャンセル", admin_users_path, class: "btn btn-outline-teal" %>
  </div>
<% end %>
