<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>訪問コネクト</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">

    <%# 検索付きプルダウン(Bootstrap 5テーマで見た目を合わせる) %>
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <header class="app-header navbar navbar-expand-md py-2">
        <div class="container-fluid px-4">
          <%= link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 me-3" do %>
            <%= render "shared/logo" %>
            <span>
              <span class="app-logo-name d-block lh-1">訪問コネクト</span>
              <span class="app-logo-tag d-none d-lg-block">訪問の予定をつなぐ。チームがつながる。</span>
            </span>
          <% end %>

          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#appNav"
                  aria-controls="appNav" aria-expanded="false" aria-label="メニュー">
            <span class="navbar-toggler-icon"></span>
          </button>

          <div class="collapse navbar-collapse" id="appNav">
            <nav class="app-nav navbar-nav me-auto">
              <%= link_to "スケジュール", root_path, class: "nav-link #{"active" if controller_name == "schedules"}" %>
              <%= link_to schedule_changes_path, class: "nav-link position-relative #{"active" if controller_name == "schedule_changes"}" do %>
                変更登録<%= render "layouts/unconfirmed_badge" %>
              <% end %>
              <%= link_to "利用者", clients_path, class: "nav-link #{"active" if controller_name == "clients"}" %>
              <%= link_to "基本ルート", recurring_visits_path, class: "nav-link #{"active" if controller_name == "recurring_visits"}" %>
              <%= link_to "変更ログ", activity_logs_path, class: "nav-link #{"active" if controller_name == "activity_logs"}" %>
              <%= link_to "休暇", staff_absences_path, class: "nav-link #{"active" if controller_name == "staff_absences"}" %>
              <% if current_user.manager? %>
                <%= link_to "スタッフ管理", admin_users_path, class: "nav-link #{"active" if controller_name == "users"}" %>
              <% end %>
            </nav>

            <div class="d-flex align-items-center gap-2">
              <span class="app-avatar"><%= current_user.name.first %></span>
              <span class="small">
                <%= current_user.name %>
                <span class="text-muted-app">(<%= t("enums.user.job.#{current_user.job}") %><%= "・#{t("enums.user.role.manager")}" if current_user.manager? %>)</span>
              </span>
              <%= button_to "ログアウト", destroy_user_session_path, method: :delete,
                            class: "btn btn-sm btn-outline-teal ms-2", form_class: "d-inline" %>
            </div>
          </div>
        </div>
      </header>
    <% end %>

    <main class="container py-4">
      <div id="flash"><%= render "layouts/flash_message" %></div>

      <%= yield %>
    </main>

    <% if user_signed_in? %>
      <%# 基本ルートの新規/編集をページ遷移なしに開くモーダル(Turbo Frameで中身を読み込む) %>
      <div class="modal fade" id="appModal" tabindex="-1" aria-hidden="true"
           data-controller="modal" data-action="turbo:submit-end->modal#submitEnd">
        <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
          <%= turbo_frame_tag "modal", class: "modal-content" %>
        </div>
      </div>
    <% end %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
  </body>
</html>
