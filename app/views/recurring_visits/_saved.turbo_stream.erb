<%# 登録/編集/削除の成功時に共通で使う差し替え。 %>
<%# グリッドと利用者詳細の逆引きをその場で更新し、フラッシュを表示する。 %>
<%# モーダルはturbo:submit-end(成功)でmodalコントローラが閉じる。 %>
<%= turbo_stream.replace "planning_grid" do %>
  <%= turbo_frame_tag "planning_grid" do %>
    <%= render "planning_section", grid: @planning_grid, service: @service %>
  <% end %>
<% end %>

<%= turbo_stream.replace "client_routes" do %>
  <%= render "client_routes", client: @recurring_visit.client %>
<% end %>

<%= turbo_stream.update "flash" do %>
  <%= render "layouts/flash_message", notice: @notice %>
<% end %>
