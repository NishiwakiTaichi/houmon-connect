<%# 変更の登録/編集/確認/取り消しの成功時に共通で差し替える部分 %>
<%# スケジュール画面では grid/panel/badge が、変更一覧ページでは行が更新される(無い対象はno-op) %>
<%= turbo_stream.replace "schedule_grid" do %>
  <%= render "schedules/grid", schedule: @schedule, service: @service, week_start: @week_start, mine: @mine %>
<% end %>

<%= turbo_stream.replace "change_panel" do %>
  <%= render "schedules/change_panel", schedule: @schedule, service: @service, week_start: @week_start, mine: @mine %>
<% end %>

<%= turbo_stream.replace "unconfirmed_badge" do %>
  <%= render "layouts/unconfirmed_badge" %>
<% end %>

<%= turbo_stream.update "flash" do %>
  <%= render "layouts/flash_message", notice: @notice %>
<% end %>

<turbo-stream action="close_modal" target="appModal"></turbo-stream>
