<div class="d-flex align-items-center mb-3">
  <h1 class="fs-4 mb-0">変更登録</h1>
  <%= link_to "＋ 変更を登録", new_schedule_change_path, class: "btn btn-coral btn-sm ms-auto",
        data: { turbo_frame: "modal" } %>
</div>

<div class="card app-card">
  <div class="card-body py-1">
    <%= tag.div id: "changes_list" do %>
      <% if @changes.any? %>
        <% @changes.each do |change| %>
          <%= render "change", change: change, with_id: true %>
        <% end %>
      <% else %>
        <p class="text-muted-app text-center py-5 mb-0" id="changes_empty">
          変更はまだ登録されていません。「＋ 変更を登録」から休み・振替などを登録できます。
        </p>
      <% end %>
    <% end %>
  </div>
</div>
