<div class="d-flex align-items-center flex-wrap gap-3 mb-3">
  <div class="seg-tabs">
    <%= link_to "リハビリ", schedules_path(service: :rehab, week: @week_start, mine: params[:mine]),
          class: ("on" if @service == "rehab") %>
    <%= link_to "看護", schedules_path(service: :nursing, week: @week_start, mine: params[:mine]),
          class: ("on" if @service == "nursing") %>
  </div>

  <div class="d-flex align-items-center gap-2 font-maru fw-bold">
    <%= link_to "◀", schedules_path(service: @service, week: @week_start - 7, mine: params[:mine]),
          class: "btn btn-sm btn-outline-teal", "aria-label": "前の週" %>
    <span><%= "#{@week_start.month}月#{@week_start.day}日(月)" %> 〜 <%= "#{(@week_start + 6).month}月#{(@week_start + 6).day}日(日)" %></span>
    <%= link_to "▶", schedules_path(service: @service, week: @week_start + 7, mine: params[:mine]),
          class: "btn btn-sm btn-outline-teal", "aria-label": "次の週" %>
    <% if @week_start != Date.current.beginning_of_week %>
      <%= link_to "今週へ", schedules_path(service: @service, mine: params[:mine]), class: "btn btn-sm btn-teal" %>
    <% end %>
  </div>

  <%= link_to(@mine ? "✓ 自分のみ" : "自分のみ表示",
        schedules_path(service: @service, week: @week_start, mine: (@mine ? nil : 1)),
        class: "btn btn-sm ms-auto #{@mine ? "btn-teal" : "btn-outline-teal"}") %>
</div>

<div class="schedule-legend mb-2">
  <span><span class="attr-badge female">女性</span> 女性スタッフ限定</span>
  <span><span class="attr-badge male">男性</span> 男性スタッフ限定</span>
  <span><span class="attr-badge newng">同行×</span> 同行不可</span>
  <span><span class="attr-badge precall">要連絡</span> 同行は事前連絡が必要</span>
</div>

<%= render "grid", schedule: @schedule, service: @service, week_start: @week_start, mine: @mine %>

<%= render "change_panel", schedule: @schedule, service: @service, week_start: @week_start, mine: @mine %>
