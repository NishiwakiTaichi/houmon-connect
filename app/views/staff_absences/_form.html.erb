<%= form_with model: absence, data: { controller: "absence-form" } do |f| %>
  <% if absence.errors.any? %>
    <div class="alert alert-danger small mb-3">
      <% absence.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <% if current_user.manager? %>
    <div class="mb-3">
      <%= f.label :user_id, class: "form-label fw-bold" %>
      <%= f.select :user_id, users.map { |u| [u.name, u.id] },
            { selected: absence.user_id },
            class: "form-select" %>
    </div>
  <% else %>
    <%= f.hidden_field :user_id, value: current_user.id %>
  <% end %>

  <div class="mb-3">
    <%= f.label :date, class: "form-label fw-bold" %>
    <%= f.date_field :date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :absence_type, class: "form-label fw-bold" %>
    <%= f.select :absence_type,
          StaffAbsence.absence_types.keys.map { |k| [I18n.t("enums.staff_absence.absence_type.#{k}"), k] },
          { selected: absence.absence_type || "full_day" },
          class: "form-select",
          data: { action: "change->absence-form#toggleHourly", "absence-form-target": "typeSelect" } %>
  </div>

  <div data-absence-form-target="hourlyFields" class="<%= "d-none" unless absence.hourly? %>">
    <div class="row g-2 mb-3">
      <div class="col-6">
        <%= f.label :start_time, class: "form-label fw-bold" %>
        <%= f.time_field :start_time, class: "form-control", value: absence.start_time&.strftime("%H:%M") %>
      </div>
      <div class="col-6">
        <%= f.label :end_time, class: "form-label fw-bold" %>
        <%= f.time_field :end_time, class: "form-control", value: absence.end_time&.strftime("%H:%M") %>
      </div>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :note, class: "form-label fw-bold" %>
    <%= f.text_field :note, class: "form-control", placeholder: "任意" %>
  </div>

  <%= f.submit "登録", class: "btn btn-coral w-100" %>
<% end %>
